NODE_ENV=development
PORT=3000
# En produccion, usar la URL privada provista por el servicio PostgreSQL.
DATABASE_URL="postgresql://postgres:<PASSWORD_URL_ENCODED>@localhost:5432/gestion_comercial?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="15m"
# Debe ser el origen exacto del frontend, sin barra final.
CORS_ORIGIN="http://localhost:5173"
APP_TIME_ZONE="America/Argentina/Buenos_Aires"
# Solo se necesita para ejecutar el seed; no es una variable de runtime.
SEED_ADMIN_PASSWORD="replace-with-a-development-admin-password"
