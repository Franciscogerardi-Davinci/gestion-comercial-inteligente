generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Business {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  taxId     String?
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  users          User[]
  categories     Category[]
  products       Product[]
  sales          Sale[]
  expenses       Expense[]
  stockMovements StockMovement[]

  @@index([name])
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  businessId   String   @db.Uuid
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Restrict)
  sales          Sale[]
  expenses       Expense[]
  stockMovements StockMovement[]

  @@index([businessId])
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  business Business  @relation(fields: [businessId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  businessId   String   @db.Uuid
  categoryId   String?  @db.Uuid
  name         String
  description  String?
  sku          String?
  barcode      String?
  salePrice    Decimal  @db.Decimal(14, 2)
  costPrice    Decimal? @db.Decimal(14, 2)
  currentStock Decimal  @default(0) @db.Decimal(14, 3)
  minimumStock Decimal  @default(0) @db.Decimal(14, 3)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Restrict)
  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@unique([businessId, sku])
  @@unique([businessId, barcode])
  @@index([businessId, name])
  @@index([categoryId])
}

model Sale {
  id          String     @id @default(uuid()) @db.Uuid
  businessId  String     @db.Uuid
  userId      String     @db.Uuid
  status      SaleStatus @default(DRAFT)
  subtotal    Decimal    @db.Decimal(14, 2)
  discount    Decimal    @default(0) @db.Decimal(14, 2)
  total       Decimal    @db.Decimal(14, 2)
  notes       String?
  confirmedAt DateTime?  @db.Timestamptz(3)
  cancelledAt DateTime?  @db.Timestamptz(3)
  createdAt   DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(3)

  business Business   @relation(fields: [businessId], references: [id], onDelete: Restrict)
  user     User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items    SaleItem[]

  @@index([businessId, createdAt])
  @@index([businessId, status])
  @@index([userId])
}

model SaleItem {
  id          String   @id @default(uuid()) @db.Uuid
  saleId      String   @db.Uuid
  productId   String   @db.Uuid
  productName String
  productSku  String?
  quantity    Decimal  @db.Decimal(14, 3)
  unitPrice   Decimal  @db.Decimal(14, 2)
  unitCost    Decimal? @db.Decimal(14, 2)
  discount    Decimal  @default(0) @db.Decimal(14, 2)
  subtotal    Decimal  @db.Decimal(14, 2)

  sale           Sale            @relation(fields: [saleId], references: [id], onDelete: Restrict)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @db.Uuid
  userId      String   @db.Uuid
  category    String
  description String
  amount      Decimal  @db.Decimal(14, 2)
  expenseDate DateTime @db.Date
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  business Business @relation(fields: [businessId], references: [id], onDelete: Restrict)
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([businessId, expenseDate])
  @@index([userId])
}

model StockMovement {
  id          String            @id @default(uuid()) @db.Uuid
  businessId  String            @db.Uuid
  productId   String            @db.Uuid
  userId      String            @db.Uuid
  saleItemId  String?           @db.Uuid
  type        StockMovementType
  quantity    Decimal           @db.Decimal(14, 3)
  stockBefore Decimal           @db.Decimal(14, 3)
  stockAfter  Decimal           @db.Decimal(14, 3)
  reason      String?
  createdAt   DateTime          @default(now()) @db.Timestamptz(3)

  business Business  @relation(fields: [businessId], references: [id], onDelete: Restrict)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  saleItem SaleItem? @relation(fields: [saleItemId], references: [id], onDelete: Restrict)

  @@index([businessId, createdAt])
  @@index([productId, createdAt])
  @@index([userId])
  @@index([saleItemId])
}
